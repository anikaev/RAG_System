RAG_APP_NAME=RAG Tutor API
RAG_APP_ENV=local
RAG_LOG_LEVEL=INFO
RAG_APP_HOST=0.0.0.0
RAG_APP_PORT=8000
RAG_REQUEST_ID_HEADER=X-Request-ID
RAG_API_PREFIX=/v1
RAG_POSTGRES_URL=postgresql+psycopg://rag:rag@postgres:5432/rag
RAG_REDIS_URL=redis://redis:6379/0
RAG_SESSION_BACKEND=database
RAG_DATABASE_FALLBACK_TO_MEMORY=true
RAG_DATABASE_BOOTSTRAP_SCHEMA=false
RAG_DATABASE_ECHO=false
RAG_SEED_DEMO_DATA_ON_STARTUP=true
RAG_LLM_PROVIDER_MODE=mock
RAG_LLM_API_KEY=
RAG_LLM_API_BASE_URL=http://127.0.0.1:8001/v1
RAG_LLM_MODEL_NAME=local-model
RAG_LLM_API_TIMEOUT_SECONDS=30
RAG_LLM_RESPONSE_FORMAT_MODE=json_object
RAG_EMBEDDING_PROVIDER_MODE=mock
RAG_EMBEDDING_API_URL=https://api.jina.ai/v1/embeddings
RAG_EMBEDDING_MODEL_NAME=jina-embeddings-v3
RAG_EMBEDDING_API_TIMEOUT_SECONDS=30
RAG_EMBEDDING_SSL_VERIFY=true
RAG_EMBEDDING_CA_BUNDLE_PATH=
RAG_RETRIEVER_BACKEND_MODE=pgvector
RAG_RETRIEVER_FALLBACK_TO_LEXICAL=true
RAG_RETRIEVAL_CACHE_BACKEND_MODE=auto
RAG_RETRIEVAL_CACHE_TTL_SECONDS=120
RAG_CODE_EXECUTION_BACKEND_MODE=stub
RAG_RUNNER_TIMEOUT_SECONDS=2
RAG_RUNNER_CPU_LIMIT=0.5
RAG_RUNNER_MEMORY_MB=128
RAG_RUNNER_BINARY=docker
RAG_RUNNER_IMAGE=rag-python-runner:latest
RAG_RUNNER_WORKDIR=/workspace
RAG_RUNNER_TESTS_PATH=app/code_tests
RAG_MAX_CHAT_MESSAGE_LENGTH=4000
RAG_MAX_CODE_LENGTH=12000
RAG_KB_SEED_PATH=app/kb/seed
RAG_KB_CHUNK_SIZE_CHARS=320
RAG_KB_CHUNK_OVERLAP_PARAGRAPHS=1
RAG_PGVECTOR_DIMENSIONS=1024

# Hugging Face Router example:
# HF_TOKEN=hf_xxx
# RAG_LLM_PROVIDER_MODE=compatible_api
# RAG_LLM_API_BASE_URL=https://router.huggingface.co/v1
# RAG_LLM_MODEL_NAME=openai/gpt-oss-120b:fireworks-ai
# RAG_LLM_RESPONSE_FORMAT_MODE=json_schema

# Jina embeddings example:
# JINA_API_KEY=jina_xxx
# RAG_EMBEDDING_PROVIDER_MODE=jina
# RAG_EMBEDDING_API_URL=https://api.jina.ai/v1/embeddings
# RAG_EMBEDDING_MODEL_NAME=jina-embeddings-v3
# RAG_EMBEDDING_CA_BUNDLE_PATH=/path/to/corporate-ca.pem
# For local debugging only:
# RAG_EMBEDDING_SSL_VERIFY=false
# RAG_RETRIEVER_BACKEND_MODE=pgvector
